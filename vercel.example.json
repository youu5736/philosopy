{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "corepack enable && pnpm install --frozen-lockfile && pnpm --filter @workspace/philosophy-librarian run build",
  "outputDirectory": "artifacts/philosophy-librarian/dist/public",
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://YOUR_RENDER_SERVICE.onrender.com/api/:path*"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
